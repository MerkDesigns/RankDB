{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RankDB",
  "version": "0.2.0",
  "identifier": "com.rankdb.desktop",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "RankDB",
        "width": 960,
        "height": 720,
        "minWidth": 440,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MerkDesigns/RankDB/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3MzQ1MEYzNTQ3MDc4NkQKUldSdGVIQlU4MUEwMTArdC9UL0ZQeEdMdFY4ZkpDNm1kL2NzeElBTTUwTTJFZG8zWko5KzdBZU8K"
    }
  }
}
