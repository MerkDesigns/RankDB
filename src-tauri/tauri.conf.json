{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RankDB",
  "version": "0.1.0",
  "identifier": "com.rankdb.desktop",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "RankDB",
        "width": 960,
        "height": 720,
        "minWidth": 440,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
